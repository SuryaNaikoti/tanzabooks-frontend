{
  "expo": {
    "name": "tanzabook",
    "slug": "tanzabook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/favlogo.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "hooks": {
      "postPublish": [
        {
          "file": "sentry-expo/upload-sourcemaps",
          "config": {
            "organization": "truequations-pvt-ltd-is",
            "project": "tanzabooks",
            "authToken": "246759f2095a4cc1a805c6c4f7b1ff45f38c40cb60bf4ceda6aafcc679df2cac"
          }
        }
      ]
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "favicon": "./assets/favlogo.png"
    },
    "plugins": ["sentry-expo"]
  }
}
